{
  "name": "yapi-typed",
  "version": "0.1.5",
  "description": "Modern YApi to TypeScript generator with plugins and templates",
  "license": "MIT",
  "type": "module",
  "bin": {
    "yapi-typed": "dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "c12": "^3.1.1",
    "change-case": "^5.4.4",
    "citty": "^0.2.0",
    "consola": "^3.2.3",
    "defu": "^6.1.4",
    "dayjs": "^1.11.11",
    "eta": "^3.5.0",
    "fs-extra": "^11.2.0",
    "form-data": "^4.0.0",
    "get-port": "^7.1.0",
    "json-schema": "^0.4.0",
    "json-schema-to-typescript": "^13.0.2",
    "json5": "^2.2.3",
    "lru-cache": "^11.0.2",
    "openapi-types": "^12.1.3",
    "prettier": "^3.3.3",
    "proxy-agent": "^6.4.0",
    "signal-exit": "^4.1.0",
    "swagger-client": "^3.27.8",
    "to-json-schema": "^0.2.5",
    "yapi-typed-runtime": "^0.1.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.11.30",
    "tsdown": "^0.20.1",
    "typescript": "^5.5.4"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
